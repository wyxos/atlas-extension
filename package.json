{
  "name": "atlas-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-extension.mjs",
    "build:local": "node scripts/build-extension.mjs --local",
    "check": "npm test && npm run lint",
    "lint": "eslint .",
    "release": "node scripts/release.mjs",
    "test": "node --test tests/*.test.mjs && node scripts/validate-extension.mjs"
  },
  "dependencies": {
    "@lucide/vue": "1.21.0",
    "@vueuse/core": "14.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "pusher-js": "^8.5.0",
    "reka-ui": "2.10.0",
    "tailwind-merge": "3.6.0",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.1",
    "@vitejs/plugin-vue": "6.0.7",
    "eslint": "10.5.0",
    "eslint-plugin-vue": "10.9.2",
    "shadcn-vue": "2.7.4",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vue-eslint-parser": "10.4.1"
  }
}
